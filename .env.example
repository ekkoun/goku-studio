# goku-studio environment variables
# Copy to .env and fill in the values.

# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=mysql+pymysql://user:pass@localhost:3306/aios
SECRET_KEY=                        # use: python -c "import secrets; print(secrets.token_hex(32))"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8107                          # Studio API port (goku-core uses 8106)
ALLOWED_ORIGINS=http://localhost:5106

# ── LLM (Studio uses LLM for agent-config previews only) ──────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Storage (agent icons / uploads) ───────────────────────────────────────────
AGENT_WORKSPACE=/tmp/agent_workspace
PUBLIC_BASE_URL=                   # e.g. https://studio.yourdomain.com

# ── Cross-service redirect URL (frontend build-time arg) ─────────────────────
# When Studio has no JWT it redirects the user to goku-core (the runtime) for
# login, then Core hands the token back via /bridge/studio.
# Set this to the public URL of the goku-core frontend so the redirect works in
# every environment.
# Pass as a Docker build arg:  --build-arg VITE_RUNTIME_URL=https://core.example.com
# For local dev the default (http://localhost:5106) is used automatically.
# VITE_RUNTIME_URL=http://localhost:5106

# ── Enterprise connectors (optional) ──────────────────────────────────────────
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# TEAMS_APP_ID=
# TEAMS_APP_PASSWORD=
# TEAMS_TENANT_ID=
